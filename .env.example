# Copy this file to `.env` for local runs. Every value below is a safe default;
# the mock SMS provider is the zero-config default, so the system runs
# end-to-end with no variables set at all. No real secrets live in this file.

# --- Database -------------------------------------------------------------
# Matches the docker-compose.yml postgres service (loopback, host port 5433).
DATABASE_URL=postgresql://cadence:cadence@localhost:5433/cadence

# --- SMS provider ---------------------------------------------------------
# mock (default) honours idempotency keys and needs no credentials.
# twilio requires the three TWILIO_* variables below and fails fast without them.
SMS_PROVIDER=mock

# --- Reply generator ------------------------------------------------------
# Simulated processing delay window, in milliseconds (uniform 3–15s default).
REPLY_DELAY_MIN_MS=3000
REPLY_DELAY_MAX_MS=15000

# --- Worker & queue -------------------------------------------------------
WORKER_CONCURRENCY=10
JOB_MAX_ATTEMPTS=3
# Lease is 4x the 15s worst-case processing time.
LEASE_DURATION_MS=60000
# Reconciliation poll interval — the safety net when a NOTIFY is missed.
RECONCILE_POLL_MS=5000

# --- API ------------------------------------------------------------------
API_PORT=3000

# --- Twilio (only when SMS_PROVIDER=twilio) -------------------------------
# Left blank on purpose: never commit real credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
